/*
  UI Tokens
  - Color: #edf1f5 #ffffff #1b2430 #5c6773 #8b95a1 #1f6feb #0f4fbf #dc5a3f #c0392b #d48a00 #a26f00 #64748b #4b5563
  - Font: 44 / 34 / 30 / 28 / 24 rpx
  - Space: 8 / 12 / 16 / 20 / 24 / 32 rpx
  - Radius: 16 / 20 / 24 / 999 rpx
  - Shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.08)
*/

page {
  background: #edf1f5;
  color: #1b2430;
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
}

.page-shell {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 24rpx calc(36rpx + env(safe-area-inset-bottom));
}

.page-stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card,
.panel-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(15, 23, 42, 0.04);
  box-sizing: border-box;
}

.card-quiet {
  background: #f7f9fc;
  box-shadow: none;
  border-color: #e4e9f0;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.section-head-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.section-title,
.headline {
  font-size: 34rpx;
  font-weight: 700;
  color: #1b2430;
  line-height: 1.35;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.25;
  color: #1b2430;
}

.sub-title {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
  color: #1b2430;
}

.text-body,
.copy {
  font-size: 28rpx;
  line-height: 1.6;
  color: #334155;
}

.text-muted,
.hint {
  font-size: 24rpx;
  line-height: 1.55;
  color: #5c6773;
}

.text-weak {
  font-size: 24rpx;
  line-height: 1.55;
  color: #8b95a1;
}

.stat-number {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.1;
  color: #1b2430;
}

.badge,
.status-chip,
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.3;
  font-weight: 600;
  border: 1rpx solid transparent;
  box-sizing: border-box;
}

.status-expiring {
  background: #fff6de;
  color: #a26f00;
  border-color: #f0d98f;
}

.status-overdue {
  background: #fee7e4;
  color: #c0392b;
  border-color: #f3b3aa;
}

.status-vacancy {
  background: #ffedd4;
  color: #b86911;
  border-color: #f0c797;
}

.status-manual {
  background: #eaf0ff;
  color: #415a8b;
  border-color: #c8d7f3;
}

.status-normal {
  background: #eef2f7;
  color: #4b5563;
  border-color: #d6deea;
}

.input,
.search-input {
  min-height: 84rpx;
  box-sizing: border-box;
  background: #f7f9fc;
  border: 1rpx solid #d8e0ea;
  border-radius: 18rpx;
  padding: 0 22rpx;
  font-size: 28rpx;
  color: #1b2430;
}

.field-label {
  font-size: 24rpx;
  color: #5c6773;
  font-weight: 500;
}

button {
  font-size: 28rpx;
}

.primary-button,
.secondary-button,
.danger-button,
.nav-button,
.text-button,
.fold-button,
.auth-button,
.logout-button {
  min-height: 82rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  line-height: 1.3;
  box-sizing: border-box;
}

.primary-button,
.auth-button,
.nav-button {
  background: #1f6feb;
  color: #ffffff;
}

.secondary-button,
.fold-button {
  background: #f2f5f9;
  color: #1b2430;
  border: 1rpx solid #d8e0ea;
}

.danger-button,
.logout-button {
  background: #c0392b;
  color: #ffffff;
}

.text-button {
  min-height: 64rpx;
  padding: 0 18rpx;
  background: #e9f2ff;
  color: #1657b8;
  border-radius: 14rpx;
  font-size: 24rpx;
}

.primary-button::after,
.secondary-button::after,
.danger-button::after,
.nav-button::after,
.text-button::after,
.fold-button::after,
.auth-button::after,
.logout-button::after {
  border: 0;
}

.empty-state {
  border-radius: 20rpx;
  padding: 22rpx;
  background: #f7f9fc;
  border: 1rpx dashed #d8e0ea;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.empty-heading {
  font-size: 30rpx;
  font-weight: 600;
  color: #1b2430;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}
