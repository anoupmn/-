/*
  UI Tokens
  - Color: #f3f6f9 #ffffff #17243a #4f5d6d #8a95a3 #17243a #223756 #e5484d #c0392b #f59f00 #9a6700 #64748b #4b5563
  - Font: 44 / 34 / 30 / 28 / 24 rpx
  - Space: 8 / 12 / 16 / 20 / 24 / 32 rpx
  - Radius: 16 / 20 / 24 / 999 rpx
  - Shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.08)
*/

page {
  background: #f3f6f9;
  color: #17243a;
  font-family: 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
}

.page-shell {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 20rpx 20rpx calc(32rpx + env(safe-area-inset-bottom));
}

.page-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card,
.panel-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 10rpx 24rpx rgba(23, 36, 58, 0.07);
  border: 1rpx solid #e6ebf1;
  box-sizing: border-box;
}

.card-quiet {
  background: #f8fafc;
  box-shadow: none;
  border-color: #e4e9f0;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.section-head-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
}

.section-title,
.headline {
  font-size: 32rpx;
  font-weight: 700;
  color: #17243a;
  line-height: 1.35;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.25;
  color: #17243a;
}

.sub-title {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.35;
  color: #17243a;
}

.text-body,
.copy {
  font-size: 28rpx;
  line-height: 1.6;
  color: #334155;
}

.text-muted,
.hint {
  font-size: 24rpx;
  line-height: 1.55;
  color: #4f5d6d;
}

.text-weak {
  font-size: 24rpx;
  line-height: 1.55;
  color: #8a95a3;
}

.stat-number {
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.1;
  color: #17243a;
}

.badge,
.status-chip,
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.3;
  font-weight: 600;
  border: 1rpx solid transparent;
  box-sizing: border-box;
}

.status-expiring {
  background: #fff6df;
  color: #9a6700;
  border-color: #f3d38b;
}

.status-overdue {
  background: #ffe8e6;
  color: #c0392b;
  border-color: #f0b8b2;
}

.status-vacancy {
  background: #ffedd4;
  color: #a15c07;
  border-color: #f0c797;
}

.status-manual {
  background: #eaf0f8;
  color: #314b72;
  border-color: #c8d7f3;
}

.status-normal {
  background: #eef2f7;
  color: #4b5563;
  border-color: #d6deea;
}

.input,
.search-input {
  min-height: 72rpx;
  box-sizing: border-box;
  background: #f8fafc;
  border: 1rpx solid #d8e0ea;
  border-radius: 14rpx;
  padding: 0 22rpx;
  font-size: 28rpx;
  color: #17243a;
}

.field-label {
  font-size: 24rpx;
  color: #4f5d6d;
  font-weight: 500;
}

button {
  font-size: 28rpx;
}

.primary-button,
.secondary-button,
.danger-button,
.nav-button,
.text-button,
.fold-button,
.auth-button,
.logout-button {
  min-height: 76rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  line-height: 1.3;
  box-sizing: border-box;
}

.primary-button,
.auth-button,
.nav-button {
  background: #17243a;
  color: #ffffff;
}

.secondary-button,
.fold-button {
  background: #f2f5f9;
  color: #1b2430;
  border: 1rpx solid #d8e0ea;
}

.danger-button,
.logout-button {
  background: #c0392b;
  color: #ffffff;
}

.text-button {
  min-height: 64rpx;
  padding: 0 18rpx;
  background: #eef3f8;
  color: #17243a;
  border-radius: 10rpx;
  font-size: 24rpx;
}

.primary-button::after,
.secondary-button::after,
.danger-button::after,
.nav-button::after,
.text-button::after,
.fold-button::after,
.auth-button::after,
.logout-button::after {
  border: 0;
}

.empty-state {
  border-radius: 14rpx;
  padding: 22rpx;
  background: #f8fafc;
  border: 1rpx dashed #d8e0ea;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.empty-heading {
  font-size: 30rpx;
  font-weight: 600;
  color: #17243a;
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}
