<view class="page-shell">
  <view class="alerts-shell page-stack">
    <view class="card intro-card">
      <view class="page-title">提醒中心</view>
      <view class="text-body">按规则分组查看问题数量与明细，先处理高优先级项，再进入列表或详情继续处理。</view>
      <view class="text-muted">分组固定：即将到期、已逾期、空置过久、人工异常。</view>
    </view>

    <view wx:if="{{isLoading}}" class="card state-card">
      <view class="text-muted">正在加载提醒分组...</view>
    </view>

    <view wx:elif="{{loadFailed}}" class="card state-card">
      <view class="text-muted">加载提醒失败，请稍后再试。</view>
    </view>

    <view wx:elif="{{!groups.length}}" class="card state-card">
      <view class="empty-heading">当前暂无异常</view>
      <view class="text-muted">今日暂无到期、逾期、空置过久或人工异常房间。</view>
    </view>

    <view
      wx:for="{{groups}}"
      wx:key="type"
      class="card group-card {{item.type === 'overdue' ? 'group-overdue' : item.type === 'expiring' ? 'group-expiring' : item.type === 'vacancy_long' ? 'group-vacancy' : 'group-manual'}}"
    >
      <view class="group-head">
        <view class="section-head-main">
          <view class="group-title-row">
            <view class="sub-title group-title">{{item.label}}</view>
            <view class="badge {{item.type === 'overdue' ? 'status-overdue' : item.type === 'expiring' ? 'status-expiring' : item.type === 'vacancy_long' ? 'status-vacancy' : 'status-manual'}}">{{item.items.length}} 条</view>
          </view>
          <view class="text-muted">优先处理最紧急项，再回到房源列表批量处理。</view>
        </view>
        <view class="group-actions">
          <button class="text-button" data-url="{{item.listUrl}}" bindtap="navigateTo">进入列表</button>
          <button class="fold-button" data-type="{{item.type}}" bindtap="toggleGroup">
            {{item.collapsed ? '展开' : '收起'}}
          </button>
        </view>
      </view>

      <view wx:if="{{!item.collapsed}}" class="group-list">
        <view
          wx:for="{{item.items}}"
          wx:key="id"
          class="alert-row"
          data-url="{{item.url}}"
          bindtap="navigateTo"
        >
          <view class="alert-head">
            <view class="alert-title">{{item.title}}</view>
            <view class="badge {{item.reason.indexOf('已逾期') !== -1 ? 'status-overdue' : item.reason.indexOf('即将到期') !== -1 ? 'status-expiring' : item.reason.indexOf('空置过久') !== -1 ? 'status-vacancy' : 'status-manual'}}">{{item.reason}}</view>
          </view>
          <view class="alert-summary text-muted">{{item.summary}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
