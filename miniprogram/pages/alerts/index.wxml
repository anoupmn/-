<view class="page-shell">
  <view class="alerts-shell page-stack">
    <view class="card hero-card">
      <view class="hero-title-row">
        <view class="page-title">提醒中心</view>
        <view class="badge status-normal">共 {{totalAlerts}} 条</view>
      </view>
      <view class="text-body">先处理“已逾期”，再处理“即将到期”和“空置过久”，最后清理人工异常。</view>
      <view class="hero-stats">
        <view wx:for="{{groups}}" wx:key="type" class="stat-chip {{item.badgeClass}}">
          {{item.label}} {{item.items.length}}
        </view>
      </view>
    </view>

    <view wx:if="{{isLoading}}" class="card state-card">
      <view class="text-muted">正在加载提醒分组...</view>
    </view>

    <view wx:elif="{{loadFailed}}" class="card state-card">
      <view class="text-muted">加载提醒失败，请稍后再试。</view>
      <button class="secondary-button retry-button" bindtap="retryLoad">重新加载</button>
    </view>

    <view wx:elif="{{!groups.length}}" class="card state-card">
      <view class="empty-heading">当前暂无异常</view>
      <view class="text-muted">今日暂无到期、逾期、空置过久或人工异常房间。</view>
    </view>

    <view
      wx:for="{{groups}}"
      wx:key="type"
      class="card group-card {{item.toneClass}}"
    >
      <view class="group-head">
        <view class="section-head-main">
          <view class="group-title-row">
            <view class="sub-title group-title">{{item.label}}</view>
            <view class="badge {{item.badgeClass}}">{{item.items.length}} 条</view>
          </view>
          <view class="text-muted">{{item.helperText}}</view>
        </view>
        <view class="group-actions">
          <button class="text-button" data-url="{{item.listUrl}}" bindtap="navigateTo">批量处理</button>
          <button class="fold-button" data-type="{{item.type}}" bindtap="toggleGroup">
            {{item.collapsed ? '展开' : '收起'}}
          </button>
        </view>
      </view>

      <view wx:if="{{!item.collapsed}}" class="group-list">
        <view
          wx:for="{{item.items}}"
          wx:key="id"
          class="alert-row"
          data-url="{{item.url}}"
          bindtap="navigateTo"
        >
          <view class="alert-main">
            <view class="alert-head">
              <view class="alert-title">{{item.title}}</view>
              <view class="badge {{item.reasonClass}}">{{item.reason}}</view>
            </view>
            <view class="alert-summary text-muted">{{item.summary}}</view>
          </view>
          <view class="alert-arrow">
            <view class="text-weak">查看</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
