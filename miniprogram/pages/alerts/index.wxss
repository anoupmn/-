.alerts-shell {
  display: flex;
  flex-direction: column;
}

.hero-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: linear-gradient(145deg, #ffffff 0%, #eef5ff 100%);
}

.hero-title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.hero-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.stat-chip {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  border: 1rpx solid transparent;
}

.state-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.retry-button {
  width: 100%;
}

.group-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  border-left: 8rpx solid transparent;
}

.tone-overdue {
  border-left-color: #dc5a3f;
}

.tone-expiring {
  border-left-color: #d4a02b;
}

.tone-vacancy {
  border-left-color: #d48a00;
}

.tone-manual {
  border-left-color: #5d7db2;
}

.group-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 14rpx;
}

.group-title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.group-title {
  line-height: 1.35;
}

.group-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.group-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.alert-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #f7f9fc;
  border: 1rpx solid #dce4ee;
  border-radius: 16rpx;
  padding: 16rpx;
}

.alert-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.alert-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 10rpx;
}

.alert-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #1b2430;
  line-height: 1.45;
}

.alert-summary {
  font-size: 24rpx;
  line-height: 1.6;
}

.alert-arrow {
  flex-shrink: 0;
  min-width: 56rpx;
  text-align: right;
}
