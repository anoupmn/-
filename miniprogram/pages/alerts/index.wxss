.alerts-shell {
  display: flex;
  flex-direction: column;
}

.alert-tabs {
  display: flex;
  gap: 10rpx;
  overflow-x: auto;
  padding-bottom: 2rpx;
}

.alert-tab {
  flex: 0 0 auto;
  min-height: 52rpx;
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #4f5d6d;
  font-size: 22rpx;
  font-weight: 600;
  border: 1rpx solid #e6ebf1;
}

.state-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.retry-button {
  width: 100%;
}

.group-card {
  display: flex;
  flex-direction: column;
  gap: 0;
  overflow: hidden;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e6ebf1;
  box-shadow: 0 8rpx 20rpx rgba(23, 36, 58, 0.05);
}

.group-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 14rpx;
  padding: 18rpx;
  background: #f8fafc;
  border-bottom: 1rpx solid #eef2f6;
}

.group-title {
  color: #17243a;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.35;
}

.group-helper {
  margin-top: 4rpx;
  color: #8a95a3;
  font-size: 22rpx;
  line-height: 1.35;
}

.fold-button {
  width: auto;
  min-height: 46rpx;
  padding: 0 14rpx;
  border-radius: 8rpx;
  background: #eef3f8;
  color: #17243a;
  font-size: 22rpx;
  line-height: 46rpx;
}

.fold-button::after {
  border: 0;
}

.group-list {
  display: flex;
  flex-direction: column;
}

.alert-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx;
  border-bottom: 1rpx solid #eef2f6;
}

.alert-row:last-child {
  border-bottom: 0;
}

.alert-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.alert-title {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  font-weight: 700;
  color: #17243a;
  line-height: 1.45;
}

.alert-summary {
  color: #5f6672;
  font-size: 22rpx;
  line-height: 1.45;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tone-overdue {
  border-left: 6rpx solid #e5484d;
}

.tone-expiring {
  border-left: 6rpx solid #f59f00;
}

.tone-vacancy {
  border-left: 6rpx solid #d98c00;
}

.tone-manual {
  border-left: 6rpx solid #2f5f9f;
}
