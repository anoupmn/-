.alerts-shell {
  display: flex;
  flex-direction: column;
}

.intro-card,
.state-card,
.group-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.intro-card {
  background: linear-gradient(145deg, #ffffff 0%, #f4f8ff 100%);
}

.group-overdue {
  border-left: 8rpx solid #dc5a3f;
}

.group-expiring {
  border-left: 8rpx solid #d4a02b;
}

.group-vacancy {
  border-left: 8rpx solid #d48a00;
}

.group-manual {
  border-left: 8rpx solid #5d7db2;
}

.group-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 14rpx;
}

.group-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.group-actions {
  display: flex;
  gap: 10rpx;
}

.group-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.alert-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  background: #f7f9fc;
  border: 1rpx solid #dce4ee;
  border-radius: 16rpx;
  padding: 16rpx;
}

.alert-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 10rpx;
}

.alert-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #1b2430;
}

.alert-summary {
  font-size: 24rpx;
}
