@import "../quick-entry/index.wxss";

.picker-field {
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 20rpx;
}

.secondary-button {
  background: #e5e7eb;
  color: #111827;
  border-radius: 999rpx;
}

.asset-card {
  padding-top: 20rpx;
  border-top: 1rpx solid #e5e7eb;
}

.asset-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

.danger-button {
  background: #ffffff;
  color: #dc2626;
  border: 1rpx solid #fecaca;
  border-radius: 999rpx;
}
