<view class="page-shell">
  <view class="card auth-card">
    <view class="auth-title">登录 / 注册</view>
    <view class="auth-copy">首次使用会自动创建你的房东工作空间，后续打开小程序会自动恢复登录状态。</view>

    <block wx:if="{{loading}}">
      <view class="auth-state">正在恢复本地会话...</view>
    </block>

    <block wx:else>
      <button class="auth-button" loading="{{submitting}}" bindtap="handleLogin">
        微信一键登录
      </button>
      <view wx:if="{{errorMessage}}" class="auth-error">{{errorMessage}}</view>
    </block>
  </view>
</view>
