.auth-shell {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100%;
}

.auth-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
  width: 100%;
}

.brand-logo {
  width: 420rpx;
  max-width: 100%;
  height: 420rpx;
}

.auth-error {
  width: 100%;
  font-size: 24rpx;
  line-height: 1.5;
  color: #c0392b;
  background: #fee7e4;
  border-radius: 14rpx;
  padding: 14rpx 16rpx;
}
