<view class="page-shell">
  <view class="card form-card">
    <view class="section-title">租约维护</view>
    <input
      class="input"
      placeholder="搜索房源名称、地址"
      bindinput="handleAssetSearch"
      value="{{assetSearchKeyword}}"
    />
    <view class="field">当前房源：{{selectedAssetName || '请先选择房源'}}</view>
    <view wx:for="{{visibleAssets}}" wx:key="id" class="asset-card">
      <view class="headline">{{item.name}}</view>
      <view class="field">{{item.address || '未填写地址'}}</view>
      <button
        class="secondary-button"
        data-asset-id="{{item.id}}"
        data-asset-name="{{item.name}}"
        bindtap="selectAsset"
      >
        选择这个房源
      </button>
    </view>
    <button
      wx:if="{{!assetSearchKeyword && assets.length > 8}}"
      class="secondary-button"
      bindtap="toggleAssetList"
    >
      {{assetListExpanded ? '收起部分房源' : '查看更多房源'}}
    </button>
    <picker range="{{rooms}}" range-key="name" value="{{roomIndex}}" bindchange="handleRoomChange">
      <view class="field picker-field">
        选择房间：{{rooms.length ? rooms[roomIndex].name : roomHint}}
      </view>
    </picker>
    <view class="hint">{{roomHint}}</view>
    <input class="input" placeholder="租户姓名" data-field="tenantName" bindinput="handleInputChange" value="{{tenantName}}" />
    <input class="input" placeholder="租户手机号" data-field="tenantPhone" bindinput="handleInputChange" value="{{tenantPhone}}" />
    <picker mode="date" value="{{startDate}}" bindchange="handleDateChange" data-field="startDate">
      <view class="field picker-field">开始日期：{{startDate}}</view>
    </picker>
    <picker mode="date" value="{{endDate}}" bindchange="handleDateChange" data-field="endDate">
      <view class="field picker-field">结束日期：{{endDate}}</view>
    </picker>
    <picker range="{{billingCycleOptions}}" bindchange="handleBillingCycleChange">
      <view class="field picker-field">收租周期：{{billingCycleDays}} 天</view>
    </picker>
    <view class="section-subtitle">固定费用</view>
    <input class="input" placeholder="租金" data-field="rentAmount" bindinput="handleInputChange" value="{{rentAmount}}" />
    <input class="input" placeholder="押金（一次性）" data-field="depositAmount" bindinput="handleInputChange" value="{{depositAmount}}" />
    <input class="input" placeholder="管理费 / 物业费" data-field="propertyAmount" bindinput="handleInputChange" value="{{propertyAmount}}" />
    <input class="input" placeholder="其他固定费用" data-field="miscAmount" bindinput="handleInputChange" value="{{miscAmount}}" />

    <view class="section-subtitle">浮动费用说明</view>
    <view class="hint">水费、电费、维修费都不适合放在租约里维护固定金额。</view>
    <view class="hint">这类费用应该在“单元详情 -> 月度账单”里按当月实际金额逐月补录。</view>
    <button class="primary-button" bindtap="handleSubmit">保存租约</button>
    <view wx:if="{{message}}" class="message">{{message}}</view>
  </view>
</view>
