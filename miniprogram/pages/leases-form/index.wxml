<view class="page-shell">
  <view class="lease-shell page-stack">
    <view class="card intro-card">
      <view class="page-title">租约维护</view>
      <view class="text-body">先选房源和房间，再录入租户与费用，保存后即可进入账单与提醒链路。</view>
      <view class="text-muted">所有信息会用于首页建议、异常识别和详情处理。</view>
    </view>

    <view class="card selection-card">
      <view class="section-title">选择房源与房间</view>
      <input
        class="search-input"
        placeholder="搜索房源名称、地址或编号"
        bindinput="handleAssetSearch"
        value="{{assetSearchKeyword}}"
      />
      <view class="search-guide">
        <view class="text-muted">默认仅展示 3 条房源，请先输入关键词模糊搜索。</view>
        <view class="text-muted">找到后直接点击整条房源卡片，卡片变蓝即选中。</view>
      </view>
      <view class="tip-row">
        <view class="field-label">当前房源</view>
        <view class="picker-value">{{selectedAssetName || '请先选择房源'}}</view>
      </view>

      <view
        wx:for="{{visibleAssets}}"
        wx:key="id"
        class="asset-item {{selectedAssetId === item.id ? 'asset-item-selected' : ''}}"
        data-asset-id="{{item.id}}"
        data-asset-name="{{item.name}}"
        bindtap="selectAsset"
      >
        <view class="sub-title asset-name">{{item.name}}</view>
        <view class="text-muted">{{item.address || '未填写地址'}}</view>
        <view class="asset-select-hint">{{selectedAssetId === item.id ? '已选中' : '点击卡片选中'}}</view>
      </view>

      <picker range="{{rooms}}" range-key="name" value="{{roomIndex}}" bindchange="handleRoomChange">
        <view class="picker-field">
          <view class="field-label">房间选择</view>
          <view class="picker-value">{{rooms.length ? rooms[roomIndex].name : roomHint}}</view>
        </view>
      </picker>
      <view class="text-muted">{{roomHint}}</view>
    </view>

    <view class="card form-card">
      <view class="section-title">租户与租期</view>
      <input class="search-input" placeholder="租户姓名" data-field="tenantName" bindinput="handleInputChange" value="{{tenantName}}" />
      <input class="search-input" placeholder="租户手机号" data-field="tenantPhone" bindinput="handleInputChange" value="{{tenantPhone}}" />

      <picker mode="date" value="{{startDate}}" bindchange="handleDateChange" data-field="startDate">
        <view class="picker-field">
          <view class="field-label">开始日期</view>
          <view class="picker-value">{{startDate}}</view>
        </view>
      </picker>
      <picker mode="date" value="{{endDate}}" bindchange="handleDateChange" data-field="endDate">
        <view class="picker-field">
          <view class="field-label">结束日期</view>
          <view class="picker-value">{{endDate}}</view>
        </view>
      </picker>

      <picker range="{{billingCycleOptions}}" bindchange="handleBillingCycleChange">
        <view class="picker-field">
          <view class="field-label">收租周期</view>
          <view class="picker-value">{{billingCycleDays}} 天</view>
        </view>
      </picker>
    </view>

    <view class="card fee-card">
      <view class="section-title">固定费用</view>
      <input class="search-input" placeholder="租金（元）" data-field="rentAmount" bindinput="handleInputChange" value="{{rentAmount}}" />
      <input class="search-input" placeholder="押金（一次性，元）" data-field="depositAmount" bindinput="handleInputChange" value="{{depositAmount}}" />
      <input class="search-input" placeholder="管理费（元）" data-field="managementAmount" bindinput="handleInputChange" value="{{managementAmount}}" />
      <picker range="{{managementCadenceOptions}}" bindchange="handleManagementCadenceChange">
        <view class="picker-field">
          <view class="field-label">管理费性质</view>
          <view class="picker-value">{{managementCadence === 'once' ? '一次性费用' : '周期性费用'}}</view>
        </view>
      </picker>
      <input class="search-input" placeholder="消防押金（一次性押金类，元）" data-field="fireDepositAmount" bindinput="handleInputChange" value="{{fireDepositAmount}}" />
      <input class="search-input" placeholder="锁卡押金（一次性押金类，元）" data-field="lockCardDepositAmount" bindinput="handleInputChange" value="{{lockCardDepositAmount}}" />

      <view class="custom-fee-header">
        <view class="sub-title">自定义费用</view>
        <button class="secondary-button compact-button" bindtap="addCustomFeeItem">添加</button>
      </view>
      <view wx:for="{{customFeeItems}}" wx:key="key" class="custom-fee-item">
        <view class="custom-fee-header">
          <view class="text-muted">自定义费用 {{index + 1}}</view>
          <button class="secondary-button compact-button delete-fee-button" data-index="{{index}}" bindtap="removeCustomFeeItem">删除</button>
        </view>
        <input class="search-input" placeholder="费用名称" data-index="{{index}}" data-field="label" bindinput="handleCustomFeeInput" value="{{item.label}}" />
        <input class="search-input" placeholder="金额（元）" data-index="{{index}}" data-field="amount" bindinput="handleCustomFeeInput" value="{{item.amount}}" />
        <picker range="{{customFeeNatureOptions}}" data-index="{{index}}" bindchange="handleCustomFeeNatureChange">
          <view class="picker-field">
            <view class="field-label">费用性质</view>
            <view class="picker-value">
              {{item.feeNature === 'deposit' ? '押金类费用' : item.feeNature === 'one_time' ? '一次性费用' : item.feeNature === 'recurring' ? '周期性费用' : '请选择'}}
            </view>
          </view>
        </picker>
      </view>

      <view class="tip-block">
        <view class="text-muted">水费、电费、维修费等浮动费用不在这里设置固定金额。</view>
        <view class="text-muted">请在“房源列表 > 单元详情 > 月度账单”按当月实际金额逐月补录。</view>
      </view>

      <button class="primary-button" bindtap="handleSubmit" loading="{{submitting}}" disabled="{{submitting}}">保存租约</button>
      <view wx:if="{{message}}" class="submit-message">{{message}}</view>
    </view>
  </view>
</view>
