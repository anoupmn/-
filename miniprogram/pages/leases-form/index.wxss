.lease-shell {
  display: flex;
  flex-direction: column;
}

.intro-card,
.selection-card,
.form-card,
.fee-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.intro-card {
  background: #ffffff;
}

.tip-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #e1e7ef;
  padding: 14rpx;
}

.search-guide {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx dashed #cbd5e1;
}

.picker-field {
  border-radius: 12rpx;
  padding: 16rpx;
  background: #f8fafc;
  border: 1rpx solid #e1e7ef;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #17243a;
  font-weight: 600;
}

.asset-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e6ebf1;
  border-radius: 14rpx;
}

.asset-item-selected {
  background: #17243a;
  border-color: #17243a;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.2);
}

.asset-name {
  font-size: 30rpx;
}

.asset-select-hint {
  font-size: 24rpx;
  color: #17243a;
  font-weight: 600;
}

.asset-item-selected .asset-name,
.asset-item-selected .text-muted,
.asset-item-selected .asset-select-hint {
  color: #ffffff;
}

.tip-block {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  border: 1rpx solid #e1e7ef;
  padding: 14rpx;
}

.labeled-input {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.custom-fee-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.custom-fee-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 14rpx;
  background: #f8fafc;
  border: 1rpx solid #e1e7ef;
  border-radius: 12rpx;
}

.compact-button {
  width: auto;
  min-width: 120rpx;
  margin: 0;
  padding: 0 18rpx;
  line-height: 56rpx;
  font-size: 24rpx;
}

.delete-fee-button {
  color: #dc2626;
  border-color: #fecaca;
  background: #fff7f7;
}

.submit-message {
  font-size: 24rpx;
  line-height: 1.5;
  color: #17243a;
  background: #eef3f8;
  border: 1rpx solid #d8e0ea;
  border-radius: 12rpx;
  padding: 12rpx 14rpx;
}
