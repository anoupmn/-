.lease-shell {
  display: flex;
  flex-direction: column;
}

.intro-card,
.selection-card,
.form-card,
.fee-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.intro-card {
  background: linear-gradient(145deg, #ffffff 0%, #f4f8ff 100%);
}

.tip-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  border-radius: 14rpx;
  background: #f7f9fc;
  border: 1rpx solid #dce4ee;
  padding: 14rpx;
}

.search-guide {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 12rpx 14rpx;
  border-radius: 14rpx;
  background: #f8fafc;
  border: 1rpx dashed #cbd5e1;
}

.picker-field {
  border-radius: 16rpx;
  padding: 16rpx;
  background: #f7f9fc;
  border: 1rpx solid #dce4ee;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #1b2430;
  font-weight: 600;
}

.asset-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 16rpx;
  background: #f7f9fc;
  border: 1rpx solid #dce4ee;
  border-radius: 16rpx;
}

.asset-item-selected {
  background: #2563eb;
  border-color: #1d4ed8;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.2);
}

.asset-name {
  font-size: 30rpx;
}

.asset-select-hint {
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 600;
}

.asset-item-selected .asset-name,
.asset-item-selected .text-muted,
.asset-item-selected .asset-select-hint {
  color: #ffffff;
}

.tip-block {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  background: #f7f9fc;
  border-radius: 14rpx;
  border: 1rpx solid #dce4ee;
  padding: 14rpx;
}

.custom-fee-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.custom-fee-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 14rpx;
  background: #f7f9fc;
  border: 1rpx solid #dce4ee;
  border-radius: 14rpx;
}

.compact-button {
  width: auto;
  min-width: 120rpx;
  margin: 0;
  padding: 0 18rpx;
  line-height: 56rpx;
  font-size: 24rpx;
}

.submit-message {
  font-size: 24rpx;
  line-height: 1.5;
  color: #1f6feb;
  background: #edf4ff;
  border: 1rpx solid #cfe0ff;
  border-radius: 14rpx;
  padding: 12rpx 14rpx;
}
