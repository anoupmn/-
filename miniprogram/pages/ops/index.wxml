<view class="page-shell">
  <view class="ops-shell">
    <view class="ops-lead">集中维护房源、租约与经营凭证</view>
    <view class="ops-list">
      <view class="ops-card">
        <view class="ops-section-title">房源管理</view>
        <view class="ops-action" data-url="/pages/assets-form/index" bindtap="navigateTo">
          <view class="column-icon icon-house">房</view>
          <view class="ops-action-copy">
            <view class="tile-title">房源维护</view>
            <view class="tile-desc">新增、编辑房源信息与状态</view>
          </view>
          <view class="action-arrow"></view>
        </view>
        <view class="ops-divider"></view>
        <view class="ops-action" bindtap="openUnitsTab">
          <view class="column-icon icon-house">房</view>
          <view class="ops-action-copy">
            <view class="tile-title">房源列表</view>
            <view class="tile-desc">查看房源明细与当前状态</view>
          </view>
          <view class="action-arrow"></view>
        </view>
      </view>

      <view class="ops-card">
        <view class="ops-section-title">租约管理</view>
        <view class="ops-action" data-url="/pages/leases-form/index" bindtap="navigateTo">
          <view class="column-icon icon-lease">约</view>
          <view class="ops-action-copy">
            <view class="tile-title">租约录入</view>
            <view class="tile-desc">录入新的租约与租赁条款</view>
          </view>
          <view class="action-arrow"></view>
        </view>
        <view class="ops-divider"></view>
        <view class="ops-action" bindtap="openLeaseList">
          <view class="column-icon icon-lease">约</view>
          <view class="ops-action-copy">
            <view class="tile-title">租约列表</view>
            <view class="tile-desc">查看租约明细与到期情况</view>
          </view>
          <view class="action-arrow"></view>
        </view>
      </view>

      <view class="ops-card">
        <view class="ops-section-title">经营凭证</view>
        <view class="ops-action" data-url="/pages/report-export/index" bindtap="navigateTo">
          <view class="column-icon icon-proof">证</view>
          <view class="ops-action-copy">
            <view class="tile-title">月度经营导出</view>
            <view class="tile-desc">导出月度经营数据与报表</view>
          </view>
          <view class="action-arrow"></view>
        </view>
        <view class="ops-divider"></view>
        <view class="ops-action" data-url="/pages/receipt-records/index" data-legacy-label="收据记录" bindtap="navigateTo">
          <view class="column-icon icon-proof">证</view>
          <view class="ops-action-copy">
            <view class="tile-title">收据管理</view>
            <view class="tile-desc">管理收据记录与打印</view>
          </view>
          <view class="action-arrow"></view>
        </view>
      </view>
    </view>
  </view>
</view>
