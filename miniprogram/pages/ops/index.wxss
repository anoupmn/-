.ops-shell {
  display: flex;
  flex-direction: column;
}

.intro-card,
.action-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.intro-card {
  background: linear-gradient(145deg, #ffffff 0%, #f4f8ff 100%);
}

.quick-card {
  border-left: 8rpx solid #1f6feb;
}

.action-buttons,
.ops-grid {
  gap: 12rpx;
}

.secondary-button,
.primary-button {
  min-height: 80rpx;
}
