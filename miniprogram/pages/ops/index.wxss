.ops-shell {
  display: flex;
  flex-direction: column;
}

.intro-card,
.action-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.intro-card {
  background: linear-gradient(145deg, #ffffff 0%, #f4f8ff 100%);
}

.step-card {
  border-left: 8rpx solid #1f6feb;
}

.action-buttons,
.ops-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.step-tip {
  padding: 12rpx 14rpx;
  border-radius: 12rpx;
  background: #f5f8fd;
  border: 1rpx solid #dde6f2;
}

.secondary-button,
.primary-button {
  min-height: 80rpx;
}
