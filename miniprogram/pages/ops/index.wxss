.page-shell {
  min-height: 100vh;
  padding: 28rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  background: #f4f8fe;
}

.ops-shell {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.ops-lead {
  padding: 0 20rpx;
  color: #7b879c;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 1.45;
}

.ops-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.ops-card {
  overflow: hidden;
  padding: 30rpx 28rpx 26rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid rgba(216, 225, 238, 0.86);
  box-shadow: 0 8rpx 24rpx rgba(23, 36, 58, 0.08);
  box-sizing: border-box;
}

.ops-section-title {
  margin-bottom: 22rpx;
  color: #10264e;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.25;
}

.ops-action {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  gap: 28rpx;
  box-sizing: border-box;
}

.column-icon {
  flex: 0 0 auto;
  width: 82rpx;
  height: 82rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1;
  box-sizing: border-box;
}

.icon-house {
  color: #1f74d4;
  background: #eaf4ff;
  border: 1rpx solid #b9dcff;
}

.icon-lease {
  color: #3f9a68;
  background: #eaf8f1;
  border: 1rpx solid #c2ecd6;
}

.icon-proof {
  color: #e98213;
  background: #fff5ec;
  border: 1rpx solid #ffd9b6;
}

.ops-action-copy {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
}

.tile-title {
  min-width: 0;
  color: #111111;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.18;
  text-align: left;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tile-desc {
  min-width: 0;
  color: #637083;
  font-size: 23rpx;
  font-weight: 400;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-arrow {
  flex: 0 0 auto;
  width: 22rpx;
  height: 22rpx;
  margin-right: 8rpx;
  border-top: 4rpx solid #8b8b8b;
  border-right: 4rpx solid #8b8b8b;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.ops-divider {
  height: 1rpx;
  margin: 12rpx 0 24rpx 110rpx;
  background: #dbe1ea;
  transform: scaleY(0.7);
  transform-origin: center;
}

.ops-action:active {
  opacity: 0.72;
}
