<view class="page-shell">
  <view class="profile-shell page-stack">
    <view class="user-card">
      <view class="user-avatar">我</view>
      <view class="user-main">
        <view class="user-name">{{displayName || '房东'}}</view>
        <view class="user-id">微信号：{{openidMasked || '未获取'}}</view>
      </view>
    </view>

    <view class="about-card">
      <view class="brand-row">
        <image class="brand-logo" src="/assets/brand/logo.jpg" mode="aspectFill" />
        <view class="brand-copy">
          <view class="about-title">收租吧</view>
          <view class="about-sub">房东经营管理小程序</view>
        </view>
      </view>
      <view class="about-copy">用于维护房源、租约、账单、收据、提醒和月度经营导出，帮房东把日常收租流程集中管理清楚。</view>
      <view class="version-row">
        <view class="field-label">版本号</view>
        <view class="version-value">v1.0.0</view>
      </view>
    </view>

    <button class="logout-button" bindtap="handleLogout">退出登录</button>
  </view>
</view>
