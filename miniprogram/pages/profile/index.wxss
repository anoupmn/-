.profile-shell {
  display: flex;
  flex-direction: column;
}

.account-card,
.subscription-card,
.action-card,
.logout-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.account-card {
  background: linear-gradient(145deg, #ffffff 0%, #f4f8ff 100%);
}

.account-name {
  font-size: 30rpx;
}

.status-panel {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  border: 1rpx solid #dde4ef;
}

.action-grid {
  gap: 12rpx;
}
