.profile-shell {
  display: flex;
  flex-direction: column;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e6ebf1;
  box-shadow: 0 8rpx 20rpx rgba(23, 36, 58, 0.05);
}

.user-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  flex: 0 0 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #17243a;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.user-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.user-name {
  color: #17243a;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1.35;
}

.user-id {
  color: #5f6672;
  font-size: 23rpx;
  line-height: 1.35;
  word-break: break-word;
}

.about-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 26rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e6ebf1;
  box-shadow: 0 8rpx 20rpx rgba(23, 36, 58, 0.05);
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-logo {
  width: 84rpx;
  height: 84rpx;
  border-radius: 18rpx;
  flex: 0 0 84rpx;
  overflow: hidden;
}

.brand-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.about-title {
  color: #17243a;
  font-size: 32rpx;
  font-weight: 700;
}

.about-sub {
  color: #8a95a3;
  font-size: 23rpx;
}

.about-copy {
  color: #4f5d6d;
  font-size: 25rpx;
  line-height: 1.6;
}

.version-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid #eef2f6;
}

.version-value {
  color: #17243a;
  font-size: 25rpx;
  font-weight: 700;
}

.logout-button {
  width: 100%;
  margin: 0;
  background: #ffffff;
  color: #c0392b;
  border: 1rpx solid #f0b8b2;
}
