<view class="page-shell">
  <view class="receipt-records-shell page-stack">
    <view class="card intro-card">
      <view class="page-title">收据记录</view>
      <view class="text-muted">集中查询已开具和已作废的收款收据。</view>
    </view>

    <view class="card issue-card">
      <view class="section-title">按租约开收据</view>
      <view class="text-muted">每个租约每个月开一张收据，已有有效收据的月份不会重复开具。</view>
      <view wx:if="{{issueError}}" class="fee-note">{{issueError}}</view>
      <view wx:if="{{!receiptLeaseOptions.length}}" class="text-muted">暂无可开收据的租约月份</view>
      <block wx:else>
        <picker range="{{receiptLeaseOptions}}" range-key="label" value="{{selectedReceiptLeaseIndex}}" bindchange="handleReceiptLeaseChange">
          <view class="field picker-field">租约：{{receiptLeaseOptions[selectedReceiptLeaseIndex].label}}</view>
        </picker>
        <picker range="{{receiptMonthOptions}}" range-key="monthLabel" value="{{selectedReceiptMonthIndex}}" bindchange="handleReceiptMonthChange">
          <view class="field picker-field">开具月份：{{receiptMonthOptions[selectedReceiptMonthIndex].monthLabel}}</view>
        </picker>
        <view wx:if="{{receiptMonthOptions[selectedReceiptMonthIndex]}}" class="field">
          将开具 {{receiptMonthOptions[selectedReceiptMonthIndex].billCount}} 笔账单，合计 ¥{{receiptMonthOptions[selectedReceiptMonthIndex].totalAmount}}
        </view>
        <button
          class="primary-button"
          loading="{{creatingReceipt}}"
          disabled="{{creatingReceipt}}"
          bindtap="createReceiptForSelectedLease"
        >
          开具该租约本月收据
        </button>
      </block>
    </view>

    <view class="card filter-card">
      <view class="filter-row">
        <picker mode="date" fields="month" value="{{month}}" bindchange="handleMonthChange">
          <view class="field picker-field">月份：{{month || '全部月份'}}</view>
        </picker>
        <button class="secondary-button compact-button" bindtap="clearMonth">全部月份</button>
      </view>

      <picker range="{{assetOptions}}" range-key="label" value="{{selectedAssetIndex}}" bindchange="handleAssetChange">
        <view class="field picker-field">房源：{{assetOptions[selectedAssetIndex].label}}</view>
      </picker>

      <picker range="{{roomOptions}}" range-key="label" value="{{selectedRoomIndex}}" bindchange="handleRoomChange">
        <view class="field picker-field">房间：{{roomOptions[selectedRoomIndex].label}}</view>
      </picker>

      <picker range="{{tenantOptions}}" range-key="label" value="{{selectedTenantIndex}}" bindchange="handleTenantChange">
        <view class="field picker-field">租客：{{tenantOptions[selectedTenantIndex].label}}</view>
      </picker>

      <picker range="{{statusOptions}}" range-key="label" value="{{selectedStatusIndex}}" bindchange="handleStatusChange">
        <view class="field picker-field">状态：{{statusOptions[selectedStatusIndex].label}}</view>
      </picker>
    </view>

    <view class="card records-card">
      <view class="section-title">收据卡片列表</view>
      <view wx:if="{{loading}}" class="text-muted">正在加载收据记录...</view>
      <view wx:elif="{{error}}" class="text-muted">{{error}}</view>
      <view wx:elif="{{!receipts.length}}" class="text-muted">暂无符合条件的收据</view>
      <view wx:for="{{receipts}}" wx:key="id" class="receipt-card">
        <view class="receipt-card-head">
          <view>
            <view class="fee-name">{{item.receiptNo}}</view>
            <view class="field">{{item.assetName}} / {{item.roomName}}</view>
          </view>
          <view class="status-pill {{item.status === 'voided' ? 'voided-pill' : ''}}">
            {{item.status === 'voided' ? '已作废' : '有效'}}
          </view>
        </view>
        <view class="field">租客：{{item.tenantName}}</view>
        <view class="field">收款日期：{{item.receivedAt}}</view>
        <view class="field">金额：¥{{item.totalAmount}} / {{item.billCount}} 笔账单</view>
        <view wx:if="{{item.reissueFromReceiptId}}" class="fee-note">由作废收据重开</view>
        <view wx:if="{{item.voidReason}}" class="fee-note">作废原因：{{item.voidReason}}</view>
        <view class="record-actions">
          <button class="secondary-button compact-button" data-id="{{item.id}}" bindtap="openReceipt">查看收据</button>
          <button class="secondary-button compact-button" data-id="{{item.roomId}}" bindtap="openRoom">回到房间</button>
        </view>
      </view>
    </view>
  </view>
</view>
