.receipt-records-shell,
.issue-card,
.filter-card,
.records-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.intro-card {
  background: linear-gradient(145deg, #ffffff 0%, #f4f8ff 100%);
}

.filter-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.filter-row .picker-field {
  flex: 1;
}

.receipt-month-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #d9dee8;
}

.month-group-head {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding: 12rpx 0;
}

.receipt-card {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 18rpx;
  border: 1rpx solid #eef1f5;
  border-radius: 12rpx;
  background: #ffffff;
}

.receipt-card-head {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.record-actions {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}
