.receipt-records-shell,
.issue-card,
.records-block,
.receipt-month-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.issue-card {
  border-top: 6rpx solid #17243a;
}

.issue-head {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.issue-label {
  width: fit-content;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #edf3fb;
  color: #17243a;
  font-size: 22rpx;
  font-weight: 700;
}

.picker-line {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 0 18rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e1e7ef;
}

.picker-value {
  min-width: 0;
  flex: 1;
  color: #17243a;
  font-size: 25rpx;
  font-weight: 600;
  text-align: right;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.issue-total {
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #17243a;
  font-size: 25rpx;
  font-weight: 600;
}

.issue-button {
  width: 100%;
  margin: 2rpx 0 0;
}

.filter-card {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e6ebf1;
  box-shadow: 0 8rpx 20rpx rgba(23, 36, 58, 0.04);
}

.filter-chip {
  width: 100%;
  min-width: 0;
  min-height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  border-radius: 10rpx;
  background: #f8fafc;
  color: #17243a;
  font-size: 23rpx;
  font-weight: 600;
  border: 1rpx solid #e6ebf1;
  box-sizing: border-box;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.month-group-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 4rpx;
}

.month-title {
  font-size: 27rpx;
  color: #17243a;
  font-weight: 700;
}

.month-status {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #e8f7ee;
  color: #178a47;
  font-size: 22rpx;
  font-weight: 600;
}

.receipt-row {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e6ebf1;
  box-shadow: 0 8rpx 20rpx rgba(23, 36, 58, 0.05);
}

.receipt-main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.receipt-title {
  color: #17243a;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-word;
}

.receipt-sub {
  color: #5f6672;
  font-size: 22rpx;
  line-height: 1.35;
  word-break: break-word;
}

.receipt-amount {
  color: #17243a;
  font-size: 26rpx;
  font-weight: 700;
}

.record-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.mini-action {
  width: 100%;
  min-width: 0;
  min-height: 50rpx;
  margin: 0;
  padding: 0 10rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #17243a;
  border: 1rpx solid #dfe5ed;
  font-size: 20rpx;
  line-height: 1.2;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.mini-action.danger {
  grid-column: 1 / -1;
  color: #e5484d;
  border-color: #f0b8b2;
}

.mini-action::after {
  border: 0;
}

.fee-note {
  color: #e5484d;
  font-size: 23rpx;
}
