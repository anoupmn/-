<view class="page-shell">
  <view class="settings-shell page-stack">
    <view wx:if="{{isLoading}}" class="card state-card">
      <view class="text-muted">正在加载提醒规则...</view>
    </view>

    <view wx:else class="card rules-card">
      <view class="section-head-main">
        <view class="section-title">启用提醒类型</view>
        <view class="text-muted">{{statusCopy}}</view>
      </view>

      <view class="rules-list">
        <view wx:for="{{rules}}" wx:key="key" class="rule-row">
          <view class="rule-main">
            <view class="rule-title-row">
              <view class="rule-label">{{item.label}}</view>
              <view class="badge {{item.key === 'overdue' ? 'status-overdue' : item.key === 'expiring' ? 'status-expiring' : item.key === 'vacancy_long' ? 'status-vacancy' : 'status-manual'}}">{{item.enabled ? '已开启' : '未开启'}}</view>
            </view>
          </view>
          <switch
            class="rule-switch"
            color="#17243a"
            checked="{{item.enabled}}"
            data-key="{{item.key}}"
            bindchange="handleRuleToggle"
          />
        </view>
      </view>
      <button class="primary-button" loading="{{isSaving}}" bindtap="saveRules">保存设置</button>
    </view>
  </view>
</view>
