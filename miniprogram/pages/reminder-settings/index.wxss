.settings-shell {
  display: flex;
  flex-direction: column;
}

.intro-card,
.state-card,
.rules-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.intro-card {
  background: linear-gradient(145deg, #ffffff 0%, #f4f8ff 100%);
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.rule-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  border: 1rpx solid #dce4ee;
}

.rule-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.rule-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.rule-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1b2430;
}

.rule-switch {
  transform: scale(0.88);
  transform-origin: center;
}
