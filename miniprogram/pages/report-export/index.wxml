<view class="page-shell">
  <view class="report-export-shell page-stack">
    <view class="card intro-card">
      <view class="page-title">月度经营导出</view>
      <view class="text-muted">导出文件包含月度明细、账单明细、房东支出明细和退租支出明细。</view>
    </view>

    <view class="card form-card">
      <picker mode="date" fields="month" value="{{month}}" bindchange="handleMonthChange">
        <view class="field picker-field">导出月份：{{month}}</view>
      </picker>

      <radio-group class="range-group" bindchange="handleRangeChange">
        <label class="range-option">
          <radio value="all" checked="{{rangeType === 'all'}}" />全部房源
        </label>
        <label class="range-option">
          <radio value="asset" checked="{{rangeType === 'asset'}}" />单个房源/楼栋
        </label>
        <label class="range-option">
          <radio value="room" checked="{{rangeType === 'room'}}" />单个房间
        </label>
      </radio-group>

      <picker wx:if="{{rangeType === 'asset' || rangeType === 'room'}}" range="{{assetOptions}}" value="{{selectedAssetIndex}}" bindchange="handleAssetChange">
        <view class="field picker-field">选择房源：{{assetOptions[selectedAssetIndex] || '暂无房源'}}</view>
      </picker>
      <picker wx:if="{{rangeType === 'room'}}" range="{{roomOptions}}" value="{{selectedRoomIndex}}" bindchange="handleRoomChange">
        <view class="field picker-field">选择房间：{{roomOptions[selectedRoomIndex] || '暂无房间'}}</view>
      </picker>

      <button class="primary-button" loading="{{exporting}}" disabled="{{exporting}}" bindtap="createExport">生成导出</button>
    </view>

    <view wx:if="{{result}}" class="card result-card">
      <view class="section-title">导出结果</view>
      <view class="field">文件：{{result.fileName}}</view>
      <view class="field">Sheet：{{result.sheetNames.join('、')}}</view>
      <view class="field">房间数：{{result.summary.roomCount}} / 账单数：{{result.summary.billCount}}</view>
      <view class="field">租客收入合计：¥{{result.summary.tenantIncomeTotal}}</view>
      <view class="field">房东支出合计：¥{{result.summary.ownerExpenseTotal}}</view>
      <button class="secondary-button" bindtap="openExportFile">打开 Excel</button>
    </view>

    <view class="card records-card">
      <view class="section-title">导出记录</view>
      <view wx:if="{{loadingExports}}" class="text-muted">正在加载导出记录...</view>
      <view wx:elif="{{!exports.length}}" class="text-muted">暂无导出记录</view>
      <view wx:for="{{exports}}" wx:key="id" class="export-record">
        <view class="record-main">
          <view class="fee-name">{{item.month}} / {{item.scopeLabel}}</view>
          <view class="field">{{item.fileName}}</view>
          <view class="field">生成时间：{{item.createdAt}}</view>
          <view class="field">租客收入 ¥{{item.summary.tenantIncomeTotal}} / 房东支出 ¥{{item.summary.ownerExpenseTotal}}</view>
        </view>
        <view class="record-actions">
          <button class="secondary-button compact-button" data-file-id="{{item.fileID}}" bindtap="openExportRecord">打开</button>
          <button
            class="danger-button compact-button"
            data-export-id="{{item.id}}"
            loading="{{deletingExportId === item.id}}"
            disabled="{{deletingExportId}}"
            bindtap="deleteExportRecord"
          >
            删除
          </button>
        </view>
      </view>
    </view>
  </view>
</view>
