.report-export-shell,
.form-card,
.result-card,
.records-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.intro-card {
  background: linear-gradient(145deg, #ffffff 0%, #f4f8ff 100%);
}

.range-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.range-option {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #22272f;
  font-size: 28rpx;
}

.export-record {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid #eef1f5;
}

.record-main,
.record-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
