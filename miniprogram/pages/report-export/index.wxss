.report-export-shell,
.export-summary,
.result-card,
.records-block {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.picker-line {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 0 18rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e1e7ef;
}

.picker-value {
  min-width: 0;
  color: #17243a;
  font-size: 25rpx;
  font-weight: 600;
  text-align: right;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.range-segments {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.range-option {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  background: #f1f4f8;
  color: #4f5d6d;
  font-size: 24rpx;
  font-weight: 600;
}

.range-option.active {
  background: #17243a;
  color: #ffffff;
}

.hidden-radio {
  display: none;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  border: 1rpx solid #e6ebf1;
  border-radius: 12rpx;
  overflow: hidden;
}

.summary-cell {
  min-height: 104rpx;
  padding: 16rpx;
  border-right: 1rpx solid #e6ebf1;
  border-bottom: 1rpx solid #e6ebf1;
  background: #ffffff;
  box-sizing: border-box;
}

.summary-cell:nth-child(2n) {
  border-right: 0;
}

.summary-cell:nth-last-child(-n + 2) {
  border-bottom: 0;
}

.summary-money {
  margin-top: 8rpx;
  color: #178a47;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 700;
}

.summary-money.danger {
  color: #e5484d;
}

.export-record {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 14rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #e6ebf1;
  box-shadow: 0 8rpx 20rpx rgba(23, 36, 58, 0.05);
}

.record-main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.record-title {
  color: #17243a;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-word;
}

.record-sub {
  color: #5f6672;
  font-size: 22rpx;
  line-height: 1.35;
  word-break: break-word;
}

.record-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.icon-button {
  width: 100%;
  min-width: 0;
  min-height: 54rpx;
  margin: 0;
  padding: 0 12rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #17243a;
  border: 1rpx solid #dfe5ed;
  font-size: 22rpx;
  line-height: 1.2;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.icon-button.danger {
  color: #e5484d;
  border-color: #f0b8b2;
}

.icon-button::after {
  border: 0;
}
