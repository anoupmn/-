<view class="page-shell" wx:if="{{detail}}">
  <view class="detail-shell">
    <view class="card summary-card">
      <view class="summary-top">
        <view>
          <view class="section-title">{{detail.summaryCard.displayName}}</view>
          <view class="field">当前租户：{{detail.summaryCard.currentTenantName || '暂无租客'}}</view>
        </view>
        <view class="status-pill">{{detail.summaryCard.mainStatusLabel}}</view>
      </view>

      <view wx:if="{{detail.summaryCard.riskTagLabels.length}}" class="tag-row">
        <view wx:for="{{detail.summaryCard.riskTagLabels}}" wx:key="*this" class="tag">{{item}}</view>
      </view>

      <view class="summary-block">
        <view class="field-label">下一笔应收</view>
        <view class="summary-main">
          <text class="summary-date">{{detail.summaryCard.nextReceivableDate || '暂无账单'}}</text>
          <text class="summary-amount" wx:if="{{detail.summaryCard.nextReceivableDate}}">
            ¥{{detail.summaryCard.nextReceivableAmount}}
          </text>
        </view>
      </view>

      <view wx:if="{{detail.summaryCard.summaryHint}}" class="summary-hint">{{detail.summaryCard.summaryHint}}</view>
      <view wx:if="{{detail.summaryCard.overdueHint}}" class="summary-hint danger-text">{{detail.summaryCard.overdueHint}}</view>
    </view>

    <view class="card">
      <view class="section-subtitle">当前租约</view>
      <view class="field" wx:if="{{detail.activeLease}}">租期：{{detail.activeLease.startDate}} 至 {{detail.activeLease.endDate}}</view>
      <view class="field" wx:if="{{detail.activeLease}}">房租：¥{{detail.activeLease.rentAmount}}</view>
      <view class="field" wx:if="{{detail.activeLease}}">押金：¥{{detail.activeLease.depositAmount}}</view>
      <view class="hint" wx:if="{{!detail.activeLease}}">当前没有生效中的租约。</view>
    </view>

    <view class="card action-card">
      <view class="section-subtitle">维修记录</view>
      <view class="hint">固定分类 + 备注，系统会自动关联到对应租住期间。</view>
      <button class="secondary-button single-action" bindtap="openRepairDialog">记录维修</button>
    </view>

    <view class="card history-card">
      <view class="section-subtitle">维修统计</view>
      <view class="field">累计维修：{{detail.repairStats.totalCount || 0}} 次</view>
      <view class="field">近 30 天：{{detail.repairStats.recent30dCount || 0}} 次</view>
      <view class="field" wx:if="{{detail.repairStats.abnormal.active}}">
        异常识别：{{detail.repairStats.abnormal.reason}}
      </view>
      <view class="field-label">主要维修类别</view>
      <view wx:if="{{!detail.repairStats.topCategories.length}}" class="hint">暂无维修记录</view>
      <view wx:for="{{detail.repairStats.topCategories}}" wx:key="category" class="field">
        {{item.label}}：{{item.count}} 次
      </view>
    </view>

    <view class="card">
      <view class="section-subtitle">月度账单</view>
      <view wx:for="{{detail.monthlyBillGroups}}" wx:key="monthKey" class="month-card">
        <view class="month-head" data-month-key="{{item.monthKey}}" bindtap="toggleMonth">
          <view>
            <view class="fee-title">{{item.monthLabel}}</view>
            <view class="hint" wx:if="{{item.isCurrentMonth}}">当前月份</view>
          </view>
          <view class="text-button">{{expandedMonths[item.monthKey] ? '收起' : '展开'}}</view>
        </view>

        <view wx:if="{{expandedMonths[item.monthKey]}}">
          <view wx:if="{{!item.items.length}}" class="hint">暂无账单记录</view>
          <view wx:for="{{item.items}}" wx:key="id" class="fee-item">
            <view class="fee-row">
              <view>
                <view class="fee-name">{{item.label}}</view>
                <view class="field">{{item.dueDate}}</view>
              </view>
              <view class="fee-status">{{item.statusLabel}}</view>
            </view>
            <view class="fee-row">
              <view class="field">应收金额：¥{{item.amount}}</view>
              <button
                wx:if="{{item.status !== 'paid'}}"
                class="mini-pay-button"
                data-bill-id="{{item.id}}"
                data-amount="{{item.amount}}"
                data-title="{{item.label}}"
                data-due-date="{{item.dueDate}}"
                bindtap="openPaymentDialog"
              >
                登记缴费
              </button>
            </view>
            <view wx:if="{{item.receivedAt}}" class="field">收款时间：{{item.receivedAt}}</view>
          </view>
          <view class="month-tools">
            <button
              class="secondary-button month-add-button"
              data-month-key="{{item.monthKey}}"
              data-month-label="{{item.monthLabel}}"
              bindtap="openManualBillDialog"
            >
              补录本月费用
            </button>
          </view>
        </view>
      </view>
    </view>

    <view class="card history-card">
      <view class="history-head">
        <view class="section-subtitle">历史租约</view>
        <button class="text-button" bindtap="toggleHistory">
          {{historyCollapsed ? '展开历史' : '收起历史'}}
        </button>
      </view>
      <view wx:if="{{!historyCollapsed}}">
        <view wx:for="{{detail.leaseHistory}}" wx:key="id" class="field">
          {{item.startDate}} 至 {{item.endDate}} / {{item.tenantName}}
        </view>
      </view>
    </view>

    <view class="card history-card">
      <view class="history-head">
        <view class="section-subtitle">历任租户</view>
      </view>
      <view wx:if="{{!historyCollapsed}}">
        <view wx:for="{{detail.tenantHistory}}" wx:key="id" class="field">
          {{item.name}}
        </view>
      </view>
    </view>

    <view class="card history-card">
      <view class="history-head">
        <view class="section-subtitle">每任租户期间维修次数</view>
      </view>
      <view wx:if="{{!historyCollapsed}}">
        <view wx:if="{{!detail.tenantPeriodRepairs.length}}" class="hint">暂无租住期间维修记录</view>
        <view wx:for="{{detail.tenantPeriodRepairs}}" wx:key="leaseId" class="field">
          {{item.tenantName}}（{{item.startDate}} 至 {{item.endDate}}）：{{item.count}} 次
        </view>
      </view>
    </view>

    <view class="card history-card">
      <view class="history-head">
        <view class="section-subtitle">历史维修</view>
      </view>
      <view wx:if="{{!historyCollapsed}}">
        <view wx:if="{{!detail.repairHistory.length}}" class="hint">暂无历史维修记录</view>
        <view wx:for="{{detail.repairHistory}}" wx:key="id" class="history-item">
          <view class="field">{{item.occurredAt}} / {{item.categoryLabel}}</view>
          <view class="field">{{item.note}}</view>
          <view class="hint" wx:if="{{item.tenantName}}">关联租户：{{item.tenantName}}</view>
          <view class="hint" wx:if="{{item.leasePeriod}}">租期：{{item.leasePeriod}}</view>
          <view class="hint" wx:if="{{!item.tenantName}}">未关联租住期间</view>
        </view>
      </view>
    </view>

    <view class="card danger-card">
      <button class="danger-button" bindtap="handleEndLease">结束租约</button>
    </view>
  </view>

  <view wx:if="{{paymentDialogVisible}}" class="dialog-mask">
    <view class="dialog-card">
      <view class="section-subtitle">登记缴费</view>
      <view class="field">{{paymentForm.title}} / {{paymentForm.dueDate}}</view>
      <input
        class="input"
        type="digit"
        value="{{paymentForm.amount}}"
        bindinput="handlePaymentAmountChange"
        placeholder="请输入收款金额"
      />
      <view class="dialog-actions">
        <button class="secondary-button" bindtap="closePaymentDialog">取消</button>
        <button class="primary-button" bindtap="confirmPayment">确认收款</button>
      </view>
    </view>
  </view>

  <view wx:if="{{manualBillDialogVisible}}" class="dialog-mask">
    <view class="dialog-card">
      <view class="section-subtitle">补录本月费用</view>
      <view class="field">{{manualBillForm.monthLabel}}</view>
      <picker range="{{manualBillTypeOptions}}" value="{{manualBillForm.typeIndex}}" bindchange="handleManualBillTypeChange">
        <view class="field picker-field">费用类型：{{manualBillTypeOptions[manualBillForm.typeIndex]}}</view>
      </picker>
      <input
        wx:if="{{manualBillMeta.showLabelInput}}"
        class="input"
        data-field="itemLabel"
        value="{{manualBillForm.itemLabel}}"
        bindinput="handleManualBillInputChange"
        placeholder="{{manualBillMeta.labelPlaceholder}}"
      />
      <input
        class="input"
        type="digit"
        data-field="amount"
        value="{{manualBillForm.amount}}"
        bindinput="handleManualBillInputChange"
        placeholder="请输入本月实际金额"
      />
      <view class="dialog-actions">
        <button class="secondary-button" bindtap="closeManualBillDialog">取消</button>
        <button class="primary-button" bindtap="confirmManualBill">确认补录</button>
      </view>
    </view>
  </view>

  <view wx:if="{{repairDialogVisible}}" class="dialog-mask">
    <view class="dialog-card">
      <view class="section-subtitle">记录维修</view>
      <picker range="{{repairCategoryOptions}}" value="{{repairForm.categoryIndex}}" bindchange="handleRepairCategoryChange">
        <view class="field picker-field">维修分类：{{repairCategoryOptions[repairForm.categoryIndex]}}</view>
      </picker>
      <picker mode="date" value="{{repairForm.occurredAt}}" bindchange="handleRepairDateChange">
        <view class="field picker-field">发生日期：{{repairForm.occurredAt || '请选择日期'}}</view>
      </picker>
      <input
        class="input"
        data-field="note"
        value="{{repairForm.note}}"
        bindinput="handleRepairInputChange"
        placeholder="请填写维修备注（必填）"
      />
      <view class="dialog-actions">
        <button class="secondary-button" bindtap="closeRepairDialog">取消</button>
        <button class="primary-button" bindtap="confirmRepairRecord">确认保存</button>
      </view>
    </view>
  </view>
</view>
