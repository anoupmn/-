<view class="page-shell" wx:if="{{detail}}">
  <view class="detail-shell">
    <view class="card summary-card">
      <view class="summary-top">
        <view>
          <view class="section-title">{{detail.summaryCard.displayName}}</view>
          <view class="field">当前租户：{{detail.summaryCard.currentTenantName || '暂无租客'}}</view>
        </view>
        <view class="status-pill">{{detail.summaryCard.mainStatusLabel}}</view>
      </view>

      <view wx:if="{{detail.summaryCard.riskTagLabels.length}}" class="tag-row">
        <view wx:for="{{detail.summaryCard.riskTagLabels}}" wx:key="*this" class="tag">{{item}}</view>
      </view>

      <view class="summary-block">
        <view class="field-label">下一笔应收</view>
        <view class="summary-main">
          <text class="summary-date">{{detail.summaryCard.nextReceivableDate || '暂无账单'}}</text>
          <text class="summary-amount" wx:if="{{detail.summaryCard.nextReceivableDate}}">
            ¥{{detail.summaryCard.nextReceivableAmount}}
          </text>
        </view>
      </view>

      <view wx:if="{{detail.summaryCard.summaryHint}}" class="summary-hint">{{detail.summaryCard.summaryHint}}</view>
      <view wx:if="{{detail.summaryCard.overdueHint}}" class="summary-hint danger-text">{{detail.summaryCard.overdueHint}}</view>
    </view>

    <view class="card">
      <view class="section-subtitle">当前租约</view>
      <view class="field" wx:if="{{detail.activeLease}}">租期：{{detail.activeLease.startDate}} 至 {{detail.activeLease.endDate}}</view>
      <view class="field" wx:if="{{detail.activeLease}}">房租：¥{{detail.activeLease.rentAmount}}</view>
      <view class="field" wx:if="{{detail.activeLease}}">押金：¥{{detail.activeLease.depositAmount}}</view>
      <view class="hint" wx:if="{{!detail.activeLease}}">当前没有生效中的租约。</view>
      <button
        wx:if="{{detail.activeLease}}"
        class="secondary-button single-action"
        data-lease-id="{{detail.activeLease.id}}"
        loading="{{renewingLease}}"
        disabled="{{renewingLease}}"
        bindtap="openRenewLeaseForm"
      >
        续租
      </button>
      <button
        wx:if="{{!detail.activeLease && canRenewLease}}"
        class="secondary-button single-action"
        loading="{{renewingLease}}"
        disabled="{{renewingLease}}"
        bindtap="openRenewLeaseForm"
      >
        续租
      </button>
    </view>

    <view class="card">
      <view class="section-subtitle">月度账单</view>
      <view wx:if="{{!detail.yearBillGroups.length}}" class="hint">暂无账单记录</view>
      <view wx:for="{{detail.yearBillGroups}}" wx:key="yearKey" wx:for-item="yearGroup" class="year-card">
        <view class="year-head" data-year-key="{{yearGroup.yearKey}}" bindtap="toggleYear">
          <view>
            <view class="fee-title">{{yearGroup.yearLabel}}</view>
            <view class="hint">{{yearGroup.months.length}} 个月账单</view>
          </view>
          <view class="text-button">{{expandedYears[yearGroup.yearKey] ? '收起' : '展开'}}</view>
        </view>

        <view wx:if="{{expandedYears[yearGroup.yearKey]}}" class="year-months">
          <view wx:for="{{yearGroup.months}}" wx:key="monthKey" wx:for-item="monthGroup" class="month-card">
        <view class="month-head" data-month-key="{{monthGroup.monthKey}}" bindtap="toggleMonth">
          <view>
            <view class="month-title">{{monthGroup.monthLabel}}</view>
            <view class="hint" wx:if="{{monthGroup.isCurrentMonth}}">当前月份</view>
          </view>
          <view class="text-button">{{expandedMonths[monthGroup.monthKey] ? '收起' : '展开'}}</view>
        </view>

        <view wx:if="{{expandedMonths[monthGroup.monthKey]}}">
          <view wx:if="{{!monthGroup.items.length}}" class="hint">暂无账单记录</view>
          <view wx:for="{{monthGroup.items}}" wx:key="id" class="fee-item">
            <view class="fee-row">
              <view>
                <view class="fee-name">{{item.label}}</view>
                <view class="field">{{item.dueDate}}</view>
              </view>
              <view class="fee-status">{{item.statusLabel}}</view>
            </view>
            <view class="fee-row">
              <view class="field">应收金额：¥{{item.amount}}</view>
              <view class="fee-actions-stack" wx:if="{{item.isManual}}">
                <button
                  wx:if="{{item.status !== 'paid'}}"
                  class="mini-pay-button compact-button"
                  data-bill-id="{{item.id}}"
                  data-amount="{{item.amount}}"
                  data-title="{{item.label}}"
                  data-due-date="{{item.dueDate}}"
                  bindtap="openPaymentDialog"
                >
                  登记缴费
                </button>
                <button
                  class="mini-delete-button compact-button"
                  data-bill-id="{{item.id}}"
                  loading="{{deletingBillId==item.id}}"
                  disabled="{{deletingBillId}}"
                  bindtap="handleDeleteManualBill"
                >
                  删除记录
                </button>
              </view>
              <button
                wx:if="{{!item.isManual && item.status !== 'paid'}}"
                class="mini-pay-button compact-button"
                data-bill-id="{{item.id}}"
                data-amount="{{item.amount}}"
                data-title="{{item.label}}"
                data-due-date="{{item.dueDate}}"
                bindtap="openPaymentDialog"
              >
                登记缴费
              </button>
            </view>
            <view wx:if="{{item.meterReading}}" class="meter-block">
              <view class="meter-grid">
                <view class="meter-cell">
                  <view class="field-label">上期读数</view>
                  <view class="meter-value">{{item.meterReading.previousReading}}</view>
                </view>
                <view class="meter-cell">
                  <view class="field-label">本期读数</view>
                  <view class="meter-value">{{item.meterReading.currentReading}}</view>
                </view>
                <view class="meter-cell">
                  <view class="field-label">用量</view>
                  <view class="meter-value">{{item.meterReading.usage}}</view>
                </view>
                <view class="meter-cell">
                  <view class="field-label">单价</view>
                  <view class="meter-value">¥{{item.meterReading.unitPrice}}</view>
                </view>
              </view>
              <view class="field">金额：¥{{item.amount}}</view>
            </view>
            <view wx:if="{{item.receivedAt}}" class="field">收款时间：{{item.receivedAt}}</view>
            <view wx:if="{{item.isReceivedAmountMismatch}}" class="fee-note">
              实收 ¥{{item.receivedAmount}}，与应收不一致
            </view>
            <view wx:if="{{item.note}}" class="fee-note">备注：{{item.note}}</view>
            <view class="fee-note" wx:if="{{item.isManual}}">补录费用</view>
          </view>
          <view class="month-tools">
            <view class="month-receipt-summary" wx:if="{{monthGroup.monthReceiptId || monthGroup.canIssueMonthReceipt}}">
              <view wx:if="{{monthGroup.monthReceiptId}}" class="field">本月收据：{{monthGroup.monthReceiptNo}}</view>
              <view wx:else class="field">本月已收 {{monthGroup.receiptableBillCount}} 笔，合计 ¥{{monthGroup.receiptableTotalAmount}}</view>
              <button
                class="primary-button month-receipt-button"
                data-month-key="{{monthGroup.monthKey}}"
                data-lease-id="{{monthGroup.receiptLeaseId}}"
                data-receipt-id="{{monthGroup.monthReceiptId}}"
                loading="{{creatingMergedReceiptMonth==monthGroup.monthKey}}"
                disabled="{{creatingMergedReceiptMonth}}"
                bindtap="createMergedMonthReceipt"
              >
                {{monthGroup.monthReceiptId ? '查看本月收据' : '开具本租约本月收据'}}
              </button>
            </view>
            <button
              class="secondary-button month-add-button"
              data-month-key="{{monthGroup.monthKey}}"
              data-month-label="{{monthGroup.monthLabel}}"
              bindtap="openManualBillDialog"
            >
              补录本月费用
            </button>
          </view>
        </view>
          </view>
        </view>
      </view>
    </view>

    <view class="card action-card">
      <view class="section-subtitle">维修/支出</view>
      <view class="hint">维修会进入问题分析；保洁、打理、请人管理等只作为房东支出留痕。</view>
      <button class="secondary-button single-action" bindtap="openRepairDialog">记录维修/支出</button>
    </view>

    <view class="card history-card">
      <view class="section-subtitle">维修统计</view>
      <view class="field">累计维修：{{detail.repairStats.totalCount || 0}} 次</view>
      <view class="field">近 30 天：{{detail.repairStats.recent30dCount || 0}} 次</view>
      <view class="field" wx:if="{{detail.repairStats.abnormal.active}}">
        异常识别：{{detail.repairStats.abnormal.reason}}
      </view>
      <view class="field-label">主要维修类别</view>
      <view wx:if="{{!detail.repairStats.topCategories.length}}" class="hint">暂无维修记录</view>
      <view wx:for="{{detail.repairStats.topCategories}}" wx:key="category" class="field">
        {{item.label}}：{{item.count}} 次
      </view>
    </view>

    <view class="card history-card">
      <view class="section-subtitle">房东支出</view>
      <view class="field">累计 {{detail.ownerExpenseSummary.count || 0}} 笔 / ¥{{detail.ownerExpenseSummary.totalAmount || 0}}</view>
      <view wx:if="{{!detail.ownerExpenses.length}}" class="hint">暂无房东支出记录</view>
      <view wx:for="{{detail.ownerExpenses}}" wx:key="id" class="expense-item">
        <view class="fee-row">
          <view>
            <view class="fee-name">{{item.typeLabel}}</view>
            <view class="field">{{item.occurredAt}} / {{item.monthKey}}</view>
          </view>
          <view class="fee-status" wx:if="{{item.amount !== null}}">¥{{item.amount}}</view>
        </view>
        <view class="fee-note" wx:if="{{item.note}}">备注：{{item.note}}</view>
      </view>
    </view>

    <view class="card history-card">
      <view class="history-head">
        <view>
          <view class="section-subtitle">历史租约</view>
          <view class="hint">每条租约可展开查看该租约内的维修明细。</view>
        </view>
      </view>

      <view wx:if="{{!leaseHistoryViews.length}}" class="hint">暂无历史租约记录</view>

      <view wx:for="{{leaseHistoryViews}}" wx:key="leaseId" class="lease-item">
        <view class="lease-head" data-lease-id="{{item.leaseId}}" bindtap="toggleLeaseHistoryItem">
          <view class="lease-main">
            <view class="lease-tenant">{{item.tenantName}}</view>
            <view class="field">联系方式：{{item.tenantPhone || '未记录'}}</view>
            <view class="field">原租约：{{item.originalPeriodLabel}}</view>
            <view class="field">实际租约：{{item.actualPeriodLabel}}</view>
            <view wx:if="{{item.terminationRemark}}" class="lease-remark">{{item.terminationRemark}}</view>
          </view>
          <view class="lease-side">
            <view class="lease-count">{{item.repairCount}} 次维修</view>
            <view class="lease-toggle">{{expandedLeaseHistory[item.leaseId] ? '收起' : '展开'}}</view>
            <button
              class="secondary-button compact-button renew-lease-button"
              data-lease-id="{{item.leaseId}}"
              loading="{{renewingLease}}"
              disabled="{{renewingLease}}"
              catchtap="openRenewLeaseForm"
            >
              续租
            </button>
          </view>
        </view>

        <view wx:if="{{expandedLeaseHistory[item.leaseId]}}" class="lease-detail">
          <view wx:if="{{!item.repairs.length}}" class="hint">该租约期间暂无维修记录</view>
          <view wx:for="{{item.repairs}}" wx:key="id" class="lease-repair-item">
            <view class="field">{{item.occurredAt}} / {{item.categoryLabel}}</view>
            <view class="field">{{item.note || '未填写备注'}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="card danger-card" wx:if="{{detail.activeLease}}">
      <button class="danger-button" bindtap="handleEndLease">结束租约</button>
      <button class="danger-button ghost-danger-button" bindtap="handleDeleteLease">安全删除租约</button>
      <view class="hint">删除仅用于录错且无历史关联的租约；已有收款、收据、维修或支出时请编辑、更正、结束或作废。</view>
    </view>
  </view>

  <view wx:if="{{renewDialogVisible}}" class="dialog-mask">
    <view class="dialog-card renew-dialog-card">
      <view class="section-subtitle">续租</view>
      <view class="field">续租开始：{{renewForm.startDate}}</view>
      <picker mode="date" value="{{renewForm.endDate}}" start="{{renewForm.startDate}}" bindchange="handleRenewDateChange">
        <view class="field picker-field">续租到期：{{renewForm.endDate || '请选择到期日'}}</view>
      </picker>
      <view class="labeled-input">
        <view class="field-label">续租租金</view>
        <input
          class="input"
          type="digit"
          data-field="rentAmount"
          value="{{renewForm.rentAmount}}"
          bindinput="handleRenewInputChange"
          placeholder="请输入金额（元）"
        />
      </view>
      <view class="labeled-input">
        <view class="field-label">周期性管理费</view>
        <input
          class="input"
          type="digit"
          data-field="managementAmount"
          value="{{renewForm.managementAmount}}"
          bindinput="handleRenewInputChange"
          placeholder="可空"
        />
      </view>
      <view class="renew-fee-head">
        <view class="field-label">周期性自定义费用</view>
        <button class="secondary-button compact-button" bindtap="addRenewCustomFeeItem">添加</button>
      </view>
      <view wx:if="{{!renewForm.customFeeItems.length}}" class="hint">暂无周期性自定义费用</view>
      <view wx:for="{{renewForm.customFeeItems}}" wx:key="key" class="renew-fee-item">
        <view class="renew-fee-head">
          <view class="field-label">费用 {{index + 1}}</view>
          <button class="mini-delete-button compact-button" data-index="{{index}}" bindtap="removeRenewCustomFeeItem">删除</button>
        </view>
        <view class="labeled-input">
          <view class="field-label">费用名称</view>
          <input
            class="input"
            data-index="{{index}}"
            data-field="label"
            value="{{item.label}}"
            bindinput="handleRenewCustomFeeInput"
            placeholder="请输入费用名称"
          />
        </view>
        <view class="labeled-input">
          <view class="field-label">费用金额</view>
          <input
            class="input"
            type="digit"
            data-index="{{index}}"
            data-field="amount"
            value="{{item.amount}}"
            bindinput="handleRenewCustomFeeInput"
            placeholder="请输入金额（元）"
          />
        </view>
      </view>
      <view class="hint">续租不会重复收押金、消防押金、锁卡押金和一次性费用；原租约会记录续租关联。</view>
      <view class="dialog-actions">
        <button class="secondary-button" disabled="{{renewingLease}}" bindtap="closeRenewDialog">取消</button>
        <button class="primary-button" loading="{{renewingLease}}" disabled="{{renewingLease}}" bindtap="confirmRenewLease">
          确认续租
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{paymentDialogVisible}}" class="dialog-mask">
    <view class="dialog-card">
      <view class="section-subtitle">登记缴费</view>
      <view class="field">{{paymentForm.title}} / {{paymentForm.dueDate}}</view>
      <input
        class="input"
        type="digit"
        value="{{paymentForm.amount}}"
        bindinput="handlePaymentAmountChange"
        placeholder="请输入收款金额"
      />
      <view class="dialog-actions">
        <button class="secondary-button" bindtap="closePaymentDialog">取消</button>
        <button class="primary-button" loading="{{paymentSubmitting}}" disabled="{{paymentSubmitting}}" bindtap="confirmPayment">
          确认收款
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{manualBillDialogVisible}}" class="dialog-mask">
    <view class="dialog-card">
      <view class="section-subtitle">补录本月费用</view>
      <view class="field">{{manualBillForm.monthLabel}}</view>
      <picker range="{{manualBillTypeOptions}}" value="{{manualBillForm.typeIndex}}" bindchange="handleManualBillTypeChange">
        <view class="field picker-field">费用类型：{{manualBillTypeOptions[manualBillForm.typeIndex]}}</view>
      </picker>
      <input
        wx:if="{{manualBillMeta.showLabelInput}}"
        class="input"
        data-field="itemLabel"
        value="{{manualBillForm.itemLabel}}"
        bindinput="handleManualBillInputChange"
        placeholder="{{manualBillMeta.labelPlaceholder}}"
      />
      <view wx:if="{{manualBillForm.typeIndex < 2}}" class="meter-form">
        <input
          class="input"
          type="digit"
          data-field="previousReading"
          value="{{manualBillForm.previousReading}}"
          bindinput="handleManualBillInputChange"
          placeholder="上期读数"
        />
        <input
          class="input"
          type="digit"
          data-field="currentReading"
          value="{{manualBillForm.currentReading}}"
          bindinput="handleManualBillInputChange"
          placeholder="本期读数"
        />
        <input
          class="input"
          type="digit"
          data-field="unitPrice"
          value="{{manualBillForm.unitPrice}}"
          bindinput="handleManualBillInputChange"
          placeholder="单价"
        />
      </view>
      <input
        wx:if="{{manualBillForm.typeIndex >= 2}}"
        class="input"
        type="digit"
        data-field="amount"
        value="{{manualBillForm.amount}}"
        bindinput="handleManualBillInputChange"
        placeholder="请输入本月实际金额"
      />
      <input
        class="input"
        data-field="note"
        value="{{manualBillForm.note}}"
        bindinput="handleManualBillInputChange"
        placeholder="备注（选填）"
      />
      <view class="dialog-actions">
        <button class="secondary-button" bindtap="closeManualBillDialog">取消</button>
        <button class="primary-button" loading="{{manualBillSubmitting}}" disabled="{{manualBillSubmitting}}" bindtap="confirmManualBill">
          确认补录
        </button>
      </view>
    </view>
  </view>

  <view wx:if="{{repairDialogVisible}}" class="dialog-mask">
    <view class="dialog-card">
      <view class="section-subtitle">记录维修/支出</view>
      <picker range="{{ownerExpenseTypeOptions}}" value="{{repairForm.expenseTypeIndex}}" bindchange="handleOwnerExpenseTypeChange">
        <view class="field picker-field">支出类型：{{ownerExpenseTypeOptions[repairForm.expenseTypeIndex]}}</view>
      </picker>
      <picker wx:if="{{repairForm.expenseTypeIndex == 0}}" range="{{repairCategoryOptions}}" value="{{repairForm.categoryIndex}}" bindchange="handleRepairCategoryChange">
        <view class="field picker-field">维修分类：{{repairCategoryOptions[repairForm.categoryIndex]}}</view>
      </picker>
      <picker mode="date" value="{{repairForm.occurredAt}}" bindchange="handleRepairDateChange">
        <view class="field picker-field">发生日期：{{repairForm.occurredAt || '请选择日期'}}</view>
      </picker>
      <input
        class="input"
        type="digit"
        data-field="amount"
        value="{{repairForm.amount}}"
        bindinput="handleRepairInputChange"
        placeholder="金额（可空）"
      />
      <input
        class="input"
        data-field="note"
        value="{{repairForm.note}}"
        bindinput="handleRepairInputChange"
        placeholder="备注（维修必填）"
      />
      <view class="dialog-actions">
        <button class="secondary-button" bindtap="closeRepairDialog">取消</button>
        <button class="primary-button" bindtap="confirmRepairRecord">确认保存</button>
      </view>
    </view>
  </view>
</view>
