@import "../quick-entry/index.wxss";

.detail-shell {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.summary-card,
.lease-card,
.action-card,
.history-card,
.year-card,
.month-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.summary-top,
.history-head,
.year-head,
.month-head,
.month-tools,
.candidate-head,
.fee-row,
.dialog-actions,
.summary-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.month-tools {
  justify-content: flex-end;
  margin-top: 20rpx;
}

.year-card {
  padding: 0;
  border-radius: 14rpx;
  border: 1rpx solid #e6ebf1;
  background: #ffffff;
  margin-top: 14rpx;
  overflow: hidden;
}

.year-head {
  align-items: center;
  padding: 18rpx;
  background: #f8fafc;
}

.year-months {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.summary-block {
  padding: 18rpx;
  border-radius: 12rpx;
  background: #f4f8fd;
  border: 1rpx solid #e1e9f4;
}

.status-pill {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e8f7ee;
  color: #178a47;
  font-size: 22rpx;
  font-weight: 600;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #f1f4f8;
  color: #4f5d6d;
  font-size: 22rpx;
}

.field-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #4f5d6d;
}

.summary-date {
  font-size: 28rpx;
  color: #17243a;
}

.summary-amount {
  font-size: 44rpx;
  font-weight: 700;
  color: #17243a;
}

.summary-hint {
  font-size: 24rpx;
  color: #5f6672;
}

.danger-text {
  color: #dc2626;
}

.action-button,
.danger-button,
.ghost-button,
.text-button {
  border-radius: 999rpx;
}

.action-card {
  align-items: stretch;
}

.action-button {
  background: #17243a;
}

.single-action {
  width: 100%;
}

.lease-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.lease-cell {
  min-height: 86rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e6ebf1;
  box-sizing: border-box;
}

.lease-cell:first-child {
  grid-column: 1 / -1;
}

.month-card {
  padding: 0 18rpx 18rpx;
  border-radius: 0;
  background: #ffffff;
  border-top: 1rpx solid #eef2f6;
}

.fee-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #17243a;
}

.month-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #17243a;
}

.fee-item {
  padding: 18rpx 0;
  border-radius: 0;
  background: #ffffff;
  border-top: 1rpx solid #eef2f6;
}

.history-item {
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.lease-item {
  border-radius: 18rpx;
  border: 1rpx solid #e2e8f0;
  background: #f8fafc;
  overflow: hidden;
}

.lease-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx;
}

.lease-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  min-width: 0;
  flex: 1;
}

.lease-tenant {
  font-size: 30rpx;
  font-weight: 600;
  color: #17243a;
}

.lease-remark {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  max-width: 100%;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #fef3c7;
  color: #b45309;
  font-size: 22rpx;
}

.lease-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  min-width: 132rpx;
}

.lease-count {
  font-size: 22rpx;
  line-height: 1.3;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  background: #eef3f8;
  color: #17243a;
}

.lease-toggle {
  font-size: 24rpx;
  color: #17243a;
}

.renew-lease-button {
  padding: 8rpx 18rpx;
  font-size: 22rpx;
}

.lease-detail {
  padding: 0 20rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.lease-repair-item {
  border-radius: 14rpx;
  border: 1rpx solid #e5e7eb;
  background: #ffffff;
  padding: 14rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.expense-item {
  border-radius: 16rpx;
  border: 1rpx solid #e5e7eb;
  background: #ffffff;
  padding: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.month-receipt-summary {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  align-items: stretch;
}

.month-receipt-button {
  width: 100%;
}

.fee-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #17243a;
}

.fee-status {
  font-size: 24rpx;
  color: #17243a;
}

.mini-pay-button {
  padding: 10rpx 24rpx;
  border-radius: 8rpx;
  background: #17243a;
  color: #ffffff;
  font-size: 24rpx;
  width: auto;
  min-width: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.mini-delete-button {
  min-width: 0;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  border: 1rpx solid #fecaca;
  background: #ffffff;
  color: #dc2626;
  font-size: 22rpx;
  line-height: 1.4;
  width: auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.fee-actions-stack {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16rpx;
}

.compact-button {
  min-width: 88rpx;
  height: 42rpx;
  line-height: 42rpx;
  padding: 0 10rpx;
  font-size: 20rpx;
}

.mini-pay-button::after,
.mini-delete-button::after {
  border: 0;
}

.fee-note {
  font-size: 22rpx;
  color: #5f6672;
}

.meter-block {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e5e7eb;
}

.meter-grid,
.meter-form {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.meter-cell {
  min-width: 0;
}

.meter-value {
  margin-top: 4rpx;
  font-size: 26rpx;
  color: #17243a;
}

.month-add-button {
  min-width: 180rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
}

.section-subtitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #17243a;
}

.text-button {
  min-height: 44rpx;
  padding: 0 12rpx;
  background: transparent;
  color: #17243a;
  line-height: 1.4;
}

.danger-card {
  padding-top: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.danger-button {
  background: #ffffff;
  color: #dc2626;
  border: 1rpx solid #fecaca;
}

.ghost-danger-button {
  color: #991b1b;
  background: #fff7f7;
}

.dialog-mask {
  position: fixed;
  inset: 0;
  background: rgba(17, 24, 39, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.dialog-card {
  width: 100%;
  max-height: 88vh;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  overflow-y: auto;
}

.picker-field {
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #e6ebf1;
}

.renew-dialog-card {
  gap: 18rpx;
}

.labeled-input {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.renew-fee-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.renew-fee-item {
  padding: 18rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e5e7eb;
  background: #f8fafc;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}
