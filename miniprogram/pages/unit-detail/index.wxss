@import "../quick-entry/index.wxss";

.detail-shell {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.summary-card,
.action-card,
.history-card,
.month-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.summary-top,
.history-head,
.month-head,
.month-tools,
.fee-row,
.dialog-actions,
.summary-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.month-tools {
  justify-content: flex-end;
  margin-top: 20rpx;
}

.summary-block {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #eff6ff;
}

.status-pill {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 24rpx;
  font-weight: 600;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #f3f4f6;
  color: #374151;
  font-size: 24rpx;
}

.field-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #6b7280;
}

.summary-date {
  font-size: 28rpx;
  color: #111827;
}

.summary-amount {
  font-size: 44rpx;
  font-weight: 700;
  color: #111827;
}

.summary-hint {
  font-size: 24rpx;
  color: #4b5563;
}

.danger-text {
  color: #dc2626;
}

.action-button,
.danger-button,
.ghost-button,
.text-button {
  border-radius: 999rpx;
}

.action-card {
  align-items: stretch;
}

.action-button {
  background: #2563eb;
}

.single-action {
  width: 100%;
}

.month-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f9fafb;
  margin-top: 20rpx;
}

.fee-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.fee-item {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f9fafb;
}

.fee-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.fee-status {
  font-size: 24rpx;
  color: #2563eb;
}

.mini-pay-button {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 24rpx;
}

.month-add-button {
  min-width: 180rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
  border-radius: 999rpx;
}

.section-subtitle {
  font-size: 28rpx;
  font-weight: 600;
}

.text-button {
  padding: 0;
  background: transparent;
  color: #2563eb;
  line-height: 1.4;
}

.danger-card {
  padding-top: 0;
}

.danger-button {
  background: #ffffff;
  color: #dc2626;
  border: 1rpx solid #fecaca;
}

.dialog-mask {
  position: fixed;
  inset: 0;
  background: rgba(17, 24, 39, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.dialog-card {
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
