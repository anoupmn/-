<view class="page-shell">
  <view class="list-shell page-stack">
    <view class="list-head">
      <view class="search-wrap">
        <input
          class="search-input"
          placeholder="搜索房源/房间/租客"
          bindinput="handleUnitSearch"
          value="{{unitSearchKeyword}}"
        />
      </view>
    </view>

    <view wx:if="{{!visibleUnits.length}}" class="card empty-card">
      <view class="empty-heading">没有匹配的房间</view>
      <view class="text-muted">可换个关键词，或清空筛选条件。</view>
    </view>

    <view class="asset-group" wx:if="{{visibleUnits.length}}">
      <view class="asset-head">
        <view class="asset-title">{{listTitle === '房源列表' ? '全部房源' : listTitle}}</view>
        <view class="asset-count">共{{units.length}}间</view>
      </view>

      <view
        wx:for="{{visibleUnits}}"
        wx:key="roomId"
        class="unit-row"
        data-room-id="{{item.roomId}}"
        bindtap="openUnitDetail"
      >
        <view class="unit-main">
          <view class="unit-name">{{item.displayName}}</view>
          <view class="unit-meta">{{item.currentTenantName || '空置'}} · {{item.nextReceivableDate || '暂无账单'}}</view>
          <view wx:if="{{item.summaryHint}}" class="unit-hint">{{item.summaryHint}}</view>
        </view>
        <view class="unit-side">
          <view class="unit-price">{{item.nextReceivableDate ? (item.nextReceivableAmount + '元/月') : '-'}}</view>
          <view class="status-chip unit-status {{item.mainStatus === 'vacant' ? 'status-vacancy' : 'status-normal'}}">{{item.mainStatusLabel}}</view>
          <view
            wx:if="{{item.riskTagLabels.length}}"
            class="risk-label {{item.riskTagLabels[0].indexOf('已逾期') !== -1 ? 'risk-overdue' : item.riskTagLabels[0].indexOf('即将到期') !== -1 ? 'risk-expiring' : 'risk-normal'}}"
          >
            {{item.riskTagLabels[0]}}
          </view>
        </view>
      </view>
    </view>

    <button wx:if="{{!unitSearchKeyword && units.length > 12}}" class="secondary-button" bindtap="toggleUnitList">
      {{unitListExpanded ? '收起部分房间' : '查看更多房间'}}
    </button>
  </view>
</view>
