.list-shell {
  display: flex;
  flex-direction: column;
}

.list-head {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.search-wrap {
  padding: 0 2rpx;
}

.search-input {
  min-height: 68rpx;
  border-radius: 18rpx;
  background: #eef2f6;
  border: 0;
  font-size: 24rpx;
}

.asset-group {
  overflow: hidden;
  border-radius: 16rpx;
  background: #ffffff;
  border: 1rpx solid #e6ebf1;
  box-shadow: 0 8rpx 20rpx rgba(23, 36, 58, 0.06);
}

.asset-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid #eef2f6;
}

.asset-title {
  font-size: 27rpx;
  color: #17243a;
  font-weight: 700;
}

.asset-count {
  font-size: 23rpx;
  color: #8a95a3;
}

.unit-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid #eef2f6;
}

.unit-row:last-child {
  border-bottom: 0;
}

.unit-main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.unit-name {
  font-size: 27rpx;
  line-height: 1.35;
  color: #17243a;
  font-weight: 700;
}

.unit-meta,
.unit-hint {
  font-size: 23rpx;
  line-height: 1.35;
  color: #5f6672;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.unit-hint {
  color: #c0392b;
}

.unit-side {
  flex: 0 0 170rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.unit-price {
  font-size: 24rpx;
  color: #17243a;
  font-weight: 600;
}

.unit-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
}

.risk-label {
  font-size: 21rpx;
  line-height: 1.3;
  color: #8a95a3;
}

.risk-overdue {
  color: #e5484d;
}

.risk-expiring {
  color: #d98200;
}

.risk-normal {
  color: #5f6672;
}

.empty-card {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
