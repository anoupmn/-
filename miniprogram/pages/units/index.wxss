.list-shell {
  display: flex;
  flex-direction: column;
}

.list-header,
.search-card,
.empty-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.list-meta {
  padding-top: 6rpx;
}

.unit-card {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 20rpx;
}

.unit-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.unit-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.unit-name {
  font-size: 30rpx;
  line-height: 1.35;
}

.unit-tenant {
  font-size: 24rpx;
}

.unit-main-status {
  margin-top: 2rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.unit-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  border: 1rpx solid #dfe6f0;
}

.metric-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.metric-item-right {
  align-items: flex-end;
  text-align: right;
}

.metric-value {
  font-size: 26rpx;
  color: #1b2430;
}

.metric-value.amount {
  font-size: 30rpx;
  font-weight: 700;
}

.summary-hint {
  font-size: 24rpx;
  line-height: 1.55;
}

.entry-hint {
  font-size: 22rpx;
}
