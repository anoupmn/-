<view class="page-shell workbench-page">
  <view class="dashboard-shell">
    <view class="card overview-panel">
      <view class="module-title">今日概览</view>
      <view class="overview-grid">
        <view
          wx:for="{{overviewCards}}"
          wx:key="key"
          class="overview-card metric-{{item.tone}}"
          data-url="{{item.url}}"
          bindtap="openOverviewCard"
        >
          <view class="metric-icon metric-icon-{{item.tone}}">
            <view wx:if="{{item.tone === 'overdue'}}" class="warn-icon">
              <view class="warn-triangle"></view>
              <view class="warn-bang">!</view>
            </view>
            <view wx:elif="{{item.tone === 'expiring'}}" class="clock-icon">
              <view class="clock-hand clock-hour"></view>
              <view class="clock-hand clock-minute"></view>
            </view>
            <view wx:elif="{{item.tone === 'vacancy'}}" class="house-icon">
              <view class="house-roof"></view>
              <view class="house-body">
                <view class="house-window"></view>
                <view class="house-window"></view>
              </view>
            </view>
            <view wx:else class="clipboard-icon">
              <view class="clip-top"></view>
              <view class="clip-line"></view>
              <view class="clip-line clip-line-short"></view>
              <view class="clip-line"></view>
            </view>
          </view>
          <view class="metric-copy">
            <view class="overview-label">{{item.label}}</view>
            <view class="overview-count-line">
              <text class="overview-count">{{item.count}}</text>
              <text class="overview-unit">{{item.unit}}</text>
            </view>
            <view class="overview-desc">{{item.desc}}</view>
          </view>
        </view>
      </view>
    </view>

    <view class="card reminder-card">
      <view class="section-head">
        <view class="section-title">15天内到期 / 待处理</view>
        <button class="plain-link" data-url="/pages/alerts/index" bindtap="navigateTo">
          <text>查看</text>
          <text class="chevron">›</text>
        </button>
      </view>
      <view class="section-subtitle">前往提醒中心，查看更多到期与待处理事项</view>

      <view wx:if="{{isLoading}}" class="empty-state">
        <view class="text-muted">正在加载...</view>
      </view>
      <view wx:elif="{{loadFailed}}" class="empty-state">
        <view class="text-muted">加载失败，请下拉重试</view>
      </view>

      <view wx:elif="{{abnormalRows.length}}" class="reminder-list">
        <view
          wx:for="{{abnormalRows}}"
          wx:key="roomId"
          class="reminder-row"
          data-url="{{item.url}}"
          bindtap="openAbnormalRow"
        >
          <view class="reminder-chip chip-{{item.tone}}">{{item.reasonLabel}}</view>
          <view class="reminder-name">{{item.displayName}}</view>
          <view class="reminder-meta">
            <text class="meta-text">{{item.supportingText}}</text>
            <text class="row-chevron">›</text>
          </view>
        </view>
      </view>

      <view wx:else class="empty-state">
        <view wx:if="{{recommendation}}" class="reminder-row fallback-row" bindtap="openRecommendation">
          <view class="reminder-chip chip-blue">{{recommendation.label}}</view>
          <view class="reminder-name">{{recommendation.title}}</view>
          <view class="reminder-meta">
            <text class="meta-text">去处理</text>
            <text class="row-chevron">›</text>
          </view>
        </view>
        <view wx:else class="empty-heading">当前暂无待处理事项</view>
      </view>
    </view>

    <view class="card todo-card">
      <view wx:if="{{recommendation}}" class="recommendation-body">
        <view class="bell-orb">
          <view class="bell-icon">
            <view class="bell-dome"></view>
            <view class="bell-base"></view>
            <view class="bell-clapper"></view>
          </view>
        </view>
        <view class="todo-text">
          <view class="todo-title">待处理提醒</view>
          <view class="todo-label">优先处理已逾期与3天内到期租约，避免漏收。</view>
        </view>
        <button class="primary-button todo-action" bindtap="openRecommendation">去处理</button>
      </view>
      <view wx:else class="empty-state">
        <view class="text-muted">暂无优先动作</view>
      </view>
    </view>
  </view>
</view>
