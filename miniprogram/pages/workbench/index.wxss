.dashboard-shell {
  display: flex;
  flex-direction: column;
}

.intro-card,
.abnormal-card,
.recommendation-card,
.reminder-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.intro-card {
  background: linear-gradient(140deg, #ffffff 0%, #f3f8ff 100%);
}

.status-line {
  padding: 14rpx 16rpx;
  border-radius: 14rpx;
  background: #f2f6fc;
  border: 1rpx solid #dbe3ef;
}

.overview-grid {
  gap: 14rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.overview-card {
  min-height: 170rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 10rpx;
  padding: 20rpx;
}

.metric-neutral {
  border-top: 6rpx solid #8b95a1;
}

.metric-expiring {
  border-top: 6rpx solid #d4a02b;
}

.metric-overdue {
  border-top: 6rpx solid #dc5a3f;
}

.metric-vacancy {
  border-top: 6rpx solid #d48a00;
}

.metric-manual {
  border-top: 6rpx solid #5d7db2;
}

.overview-label {
  font-size: 24rpx;
  color: #5c6773;
  font-weight: 600;
  line-height: 1.45;
}

.overview-count {
  font-size: 44rpx;
}

.overview-foot {
  font-size: 22rpx;
}

.abnormal-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.abnormal-row {
  background: #f8fafd;
  border: 1rpx solid #e1e7f0;
  border-radius: 18rpx;
  padding: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.abnormal-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.abnormal-name {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #1b2430;
}

.abnormal-reason {
  max-width: 44%;
  text-align: center;
}

.abnormal-support {
  font-size: 24rpx;
}

.recommendation-body {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.recommendation-title {
  font-size: 30rpx;
}

.reminder-card {
  gap: 14rpx;
}
