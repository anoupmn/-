{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["jest", "node", "miniprogram-api-typings"],
    "baseUrl": ".",
    "outDir": "dist"
  },
  "include": [
    "miniprogram/**/*.ts",
    "cloudfunctions/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "**/* 2.ts"
  ]
}
